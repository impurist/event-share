# Copy to `pact/.env` and fill in — or just export these in your shell.
# NEVER commit real credentials.

# Your PactFlow tenant + a read/write API token.
PACT_BROKER_BASE_URL=https://<your-tenant>.pactflow.io
PACT_BROKER_TOKEN=<your-pactflow-token>

# Version + branch stamped onto published contracts.
# Left blank, the scripts fall back to the current git short-SHA / branch.
GIT_SHA=
GIT_BRANCH=

# Environment used by can-i-deploy / record-deployment.
DEPLOY_ENVIRONMENT=production

# Optional overrides:
# PACT_IMAGE=pactfoundation/pact-cli:latest   # Docker image providing the pact CLIs
# DRY_RUN=1                                    # print commands instead of executing them
