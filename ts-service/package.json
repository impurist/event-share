{
  "name": "music-events-ts-service",
  "version": "1.0.0",
  "private": true,
  "description": "TypeScript publisher + subscriber for the Music Performance Event AsyncAPI example",
  "type": "module",
  "scripts": {
    "subscribe": "tsx src/subscribe.ts",
    "publish": "tsx src/publish.ts",
    "start": "tsx src/subscribe.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:pact": "vitest run --config vitest.pact.config.ts",
    "verify:provider": "tsx src/verify-provider-contract.ts",
    "cross-check": "tsx cross-check.ts"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "amqplib": "^0.10.4",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@pact-foundation/pact": "^17.0.0",
    "@types/amqplib": "^0.10.5",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^26.0.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  }
}
